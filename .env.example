# Stremio Discord Presence Configuration
#
# The Discord Client ID is built into the app, so it is NOT configured here.
# These optional settings are only for development / advanced use.

# Interval in milliseconds to check if Stremio is running (default: 5000 = 5 seconds)
POLL_INTERVAL_MS=5000

# Toggle Privacy Mode by default (true/false)
# If true, details about what is being watched will be hidden.
PRIVACY_MODE=false

# Note: Poster artwork uses Stremio's own Cinemeta metadata addon and needs
# no API key. It can be turned off any time via the "Show Poster Art" tray toggle.
